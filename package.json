{
  "name": "d5-spam-guard-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Discord bot that moderates fake successful withdrawal images.",
  "type": "module",
  "main": "src/index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:visual-references": "node scripts/build-visual-reference-manifest.mjs",
    "build:easter-egg-photos": "node scripts/build-easter-egg-photo-manifest.mjs",
    "prestart": "pnpm build:visual-references && pnpm build:easter-egg-photos",
    "start": "node src/index.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "sharp": "^0.34.3",
    "tesseract.js": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "6.27.0"
    }
  }
}
